HOST=0.0.0.0
PORT=7860
MAX_UPLOAD_MB=50
TEMP_DIR=/tmp/s-trans
LOG_LEVEL=INFO
REUSE_TRANSLATIONS=true
DEFAULT_CHUNK_TOKENS=2500
CONCURRENT_CHUNKS=4
MAX_CONCURRENT_JOBS=4
LIBREOFFICE_BIN=soffice

# Notes (prose only — do NOT paste this block into Coolify's env editor,
# some tools mis-parse "# KEY=value" lines as real variables).
#
# LOG_LEVEL=DEBUG routes verbose LLM prompts and raw responses to a rotating
# log file at $TEMP_DIR/s-trans.log; the terminal stays at INFO.
#
# REUSE_TRANSLATIONS=false disables job dedup so every upload re-runs the LLM
# even if an identical file was translated recently.
#
# MAX_CONCURRENT_JOBS caps how many whole-document jobs may run in parallel
# through the FIFO queue. Set to 1 on a shared server so users wait their
# turn; bump higher when running locally on a powerful box.
#
# Shared-key mode: set a provider's standard key env (ANTHROPIC_API_KEY,
# OPENAI_API_KEY, DEEPSEEK_API_KEY, GEMINI_API_KEY, GROQ_API_KEY,
# MISTRAL_API_KEY, OPENROUTER_API_KEY) and the UI will offer a "use shared
# key" button. If you set more than one, also set SHARED_KEY_PROVIDER to
# pick which one is advertised. Default model and the caveat note shown
# next to the button come from the UI's built-in per-provider table.
