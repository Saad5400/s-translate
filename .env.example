HOST=0.0.0.0
PORT=7860
MAX_UPLOAD_MB=50
TEMP_DIR=/tmp/s-trans
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG routes verbose LLM prompts, raw responses, and parsed
# translations to a rotating log file (default $TEMP_DIR/s-trans.log) while
# the terminal stays at INFO. Override the path with LOG_FILE=/path/to/log.
# LOG_FILE=/tmp/s-trans/s-trans.log
# REUSE_TRANSLATIONS=false disables job dedup, forcing every upload to re-run
# the LLM even if an identical file was translated recently.
REUSE_TRANSLATIONS=true
DEFAULT_CHUNK_TOKENS=2500
CONCURRENT_CHUNKS=4
# Every upload goes through a FIFO queue. MAX_CONCURRENT_JOBS caps how many
# whole-document jobs may run in parallel — set to 1 on a shared server so
# users wait their turn, or higher when running locally on a powerful box.
MAX_CONCURRENT_JOBS=4
LIBREOFFICE_BIN=soffice
