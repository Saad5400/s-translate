HOST=0.0.0.0
PORT=7860
MAX_UPLOAD_MB=50
TEMP_DIR=/tmp/s-trans
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG routes verbose LLM prompts, raw responses, and parsed
# translations to a rotating log file (default $TEMP_DIR/s-trans.log) while
# the terminal stays at INFO. Override the path with LOG_FILE=/path/to/log.
# LOG_FILE=/tmp/s-trans/s-trans.log
# REUSE_TRANSLATIONS=false disables job dedup, forcing every upload to re-run
# the LLM even if an identical file was translated recently.
REUSE_TRANSLATIONS=true
DEFAULT_CHUNK_TOKENS=2500
CONCURRENT_CHUNKS=4
# Every upload goes through a FIFO queue. MAX_CONCURRENT_JOBS caps how many
# whole-document jobs may run in parallel — set to 1 on a shared server so
# users wait their turn, or higher when running locally on a powerful box.
MAX_CONCURRENT_JOBS=4
LIBREOFFICE_BIN=soffice

# Shared-key mode — when the deploy ships a provider key, the UI offers
# a "use shared key" button so end users don't need to bring their own.
#
# 1. Set the provider's standard key env (LiteLLM auto-reads these):
#      ANTHROPIC_API_KEY  OPENAI_API_KEY  DEEPSEEK_API_KEY
#      GEMINI_API_KEY     GROQ_API_KEY    MISTRAL_API_KEY
#      OPENROUTER_API_KEY
# 2. If exactly one is set, /api/config auto-advertises that provider.
# 3. If multiple are set (or you want a non-standard pick), force it with:
#      SHARED_KEY_PROVIDER=deepseek
# 4. Optional overrides for the shared button's defaults:
#      SHARED_KEY_MODEL=deepseek-chat
#      SHARED_KEY_API_BASE=https://api.deepseek.com/v1
#      SHARED_KEY_NOTE="نموذج صيني — قد ينفد رصيد الرموز"  # falls back to a built-in per-provider caveat
# DEEPSEEK_API_KEY=
# SHARED_KEY_PROVIDER=deepseek
